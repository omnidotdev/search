{
  "name": "@omnidotdev/search",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "Meilisearch wrapper with multi-tenant support for Omni products",
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "vite build",
    "check": "biome check --diagnostic-level=error src",
    "clean": "rm -rf build node_modules",
    "dev": "vite build --watch",
    "format": "biome format --write src",
    "knip": "knip-bun --cache --tags=-knipignore",
    "lint": "biome lint --write src",
    "release": "bun run build && changeset publish",
    "test": "bun test",
    "prepare": "husky"
  },
  "keywords": [
    "omni",
    "meilisearch",
    "search",
    "multi-tenant"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/omnidotdev/search#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omnidotdev/search.git"
  },
  "bugs": "https://github.com/omnidotdev/search/issues",
  "author": "Omni <hey@omni.dev>",
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "meilisearch": "^0.48.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "^1.3.6",
    "husky": "^9.1.7",
    "knip": "^5.82.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
